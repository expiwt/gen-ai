# Настройки LLM (OpenAI-совместимый API)
# Для DeepSeek:   OPENAI_BASE_URL=https://api.deepseek.com/beta
# Для OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1
# Для кастомного: OPENAI_BASE_URL=https://ваш-адрес/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.deepseek.com/beta
LLM_MODEL=deepseek-chat

# Для sentence-transformers (RAG) — будет скачан автоматически
# (lazy import — модель грузится только при первом запросе)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
